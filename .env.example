# Resend email service (resend.com)
RESEND_API_KEY=

# Resend audience ID for newsletter subscribers
RESEND_AUDIENCE_ID=

# Resend audience ID for consultation form submitters
RESEND_CONSULTATION_AUDIENCE_ID=

# Email where form notifications are sent (default: miklosjelencsity@gmail.com)
NOTIFY_EMAIL=

# Secret token for protecting the /nezor-utmutato guide page
GUIDE_TOKEN=

# Facebook Page ID for Messenger chat widget
NEXT_PUBLIC_FB_PAGE_ID=

# Site base URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://nezor.hu

# Google Analytics 4 measurement ID (optional override, default: G-X79GL5MKMH)
NEXT_PUBLIC_GA4_ID=G-X79GL5MKMH

# Facebook Pixel ID — Meta Ads Manager > Events Manager > Pixel ID
NEXT_PUBLIC_FB_PIXEL_ID=

# Meta Conversions API token — Events Manager > Dataset > Beállítások > Konverziók API > Token generálása
META_CAPI_TOKEN=

# Csak TESZTHEZ: a Meta "Események tesztelése" fülén látható teszt kód (pl. TEST37428).
# Ha ki van töltve, a szerver oldali (CAPI) események is megjelennek ott.
# ÉLESBEN HAGYD ÜRESEN, különben a Meta nem számolja be rendesen a konverziókat!
META_TEST_EVENT_CODE=
